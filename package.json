{
	"name": "se_project_react",
	"private": true,
	"version": "0.0.0",
	"type": "module",
	"homepage": "https://twighlightparadox.mooo.com",
	"scripts": {
		"dev": "vite --open",
		"dev:host": "vite --open --host",
		"server": "json-server --watch db.json --port 3001 --id _id",
		"dev:all": "concurrently \"npm run server\" \"npm run dev\"",
		"dev:all:host": "concurrently \"npm run server\" \"npm run dev:host\"",
		"start": "npm run server",
		"build": "vite build",
		"lint": "eslint . --ext js,jsx --report-unused-disable-directives --max-warnings 0",
		"preview": "vite preview",
		"deploy": "npm run build && scp -r ./dist/* romanshawn3@twighlightparadox.mooo.com:/home/romanshawn3/frontend"
	},
	"dependencies": {
		"react": "^18.3.1",
		"react-dom": "^18.3.1",
		"react-router-dom": "^6.30.3"
	},
	"devDependencies": {
		"@types/react": "^18.3.3",
		"@types/react-dom": "^18.3.0",
		"@vitejs/plugin-react": "^4.3.1",
		"concurrently": "^9.2.1",
		"eslint": "^8.57.0",
		"eslint-plugin-react": "^7.34.2",
		"eslint-plugin-react-hooks": "^4.6.2",
		"eslint-plugin-react-refresh": "^0.4.7",
		"gh-pages": "^6.3.0",
		"json-server": "^0.17.4",
		"vite": "^7.3.1"
	}
}
